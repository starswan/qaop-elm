{
  "name": "retroelm",
  "private": true,
  "dependencies": {
    "@rails/ujs": "7.1.501",
    "elm": "^0.19.1-6",
    "elm-optimize-level-2": "^0.3.5",
    "esbuild": "^0.15.18"
  },
  "overrides": {
    "cross-spawn": ">= 7.0.3"
  },
  "version": "0.1.0",
  "devDependencies": {
    "elm-format": "^0.8.8",
    "elm-test": "0.19.1-revision16",
    "esbuild-plugin-elm": "^0.0.12",
    "sass": "^1.89.2"
  },
  "scripts": {
    "build": "elm-optimize-level-2 app/javascript/Main.elm --optimize-speed --output app/assets/builds/hello_elm.js",
    "build:css": "sass ./app/assets/stylesheets/application.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules --quiet-deps --style compressed"
