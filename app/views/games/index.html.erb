<%- model_class = Game -%>
<div class="page-header">
  <h1><%=t '.title', :default => model_class.model_name.human.pluralize.titleize %></h1>
</div>
<table class="table table-striped table-responsive">
  <tbody>
      <% @games.in_groups_of(4).each do |group| %>
      <tr>
        <% group.compact.each do |game| %>
          <% if game.picture_url.present? %>
            <td><%= game.name %><br/>
              <span id="<%= "game_#{game.id}" %>">
                <%= link_to (image_tag game.picture_url, height: 192), game_path(game) %>
              </span>
            </td>
          <% else %>
            <td colspan="2"><%= link_to game.name, game_path(game) %></td>
          <% end %>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
