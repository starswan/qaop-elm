    <%= vite_client_tag %>

    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%#= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%#= vite_javascript_tag "hello_elm", type: "module" %>
